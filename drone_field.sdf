            <diffuse>0.8 0.8 0.8 1</diffuse>
            <emissive>0 0 0 1</emissive>
            <pbr>
              <metal>
                <albedo_map>file:///home/ryder/Task_flight_ws/drone_field_meshes/textures/hazard_flammable.png</albedo_map>
                <metalness>0</metalness>
                <roughness>1</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
      <!-- 健康危害标识 — 蓝底, 筒3 (68.5, 7.0) -->
