            <pbr>
              <metal>
                <albedo_map>file:///home/ryder/Task_flight_ws/drone_field_meshes/textures/hazard_health.png</albedo_map>
                <metalness>0</metalness>
                <roughness>1</roughness>
              </metal>
            </pbr>
          </material>
        </visual>
      </link>
      <!-- 危险标识 — 红底, 筒5 (69.0, 1.5) -->
