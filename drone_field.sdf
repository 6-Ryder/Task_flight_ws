    <!-- 危险品标识板 (12cm×12cm×1cm, 贴地, 标识朝上)                 -->
    <!--   PBR纹理 + 匹配底色, 提高可见性                              -->
    <!--   标识来源: PDF 第1页(易燃/橙), 第7页(健康/蓝), 第10页(危险/红) -->
    <!-- ============================================================ -->
    <model name="hazard_plates">
      <static>true</static>
      <!-- 易燃标识 — 橙底, 筒1 (66.0, 2.0) -->
      <link name="hazard_plate_1">
        <pose>66.0 2.0 0.010 0 0 0</pose>
